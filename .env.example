# Public (sent to browser)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_UMBRA_NETWORK=mainnet
NEXT_PUBLIC_SOLANA_RPC_URL=
NEXT_PUBLIC_SOLANA_WS_URL=
NEXT_PUBLIC_USDC_MINT=
NEXT_PUBLIC_UMBRA_INDEXER_URL=https://utxo-indexer.api.umbraprivacy.com

# Server-only: require getSignatureStatuses RPC check before marking intent settled (recommended for production).
# When unset or false, demo/local flows can confirm without landed transactions.
REQUIRE_ONCHAIN_CONFIRM_FOR_SETTLE=

# Optional merchant webhook: POST /api/intents JSON body `webhookUrl` (http or https).
# On first successful settlement the server POSTs JSON { event: "intent.settled", intentId, ... } (best-effort, 8s timeout).
